# ============================================================
# TourSafe — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Next.js Frontend ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── FastAPI Backend ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/toursafe
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT / Auth
SECRET_KEY=change-this-to-a-long-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Blockchain (Polygon Amoy Testnet) ────────────────────────
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
WALLET_PRIVATE_KEY=your-wallet-private-key-hex-without-0x
DID_REGISTRY_ADDRESS=0xYourSmartContractAddressOnAmoy

# ── Redis (for rate limiting / caching) ─────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ML Models ────────────────────────────────────────────────
ONNX_MODEL_PATH=ml_models/anomaly_lstm.onnx

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://toursafe.gov.in

# ── Environment ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
